# Monorepo-wide ignores (each service may also have its own .gitignore)

# Build artifacts (e.g. Lambda deployment zips)
build/
dist/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# Node (in case a teammate's service / frontend uses it)
node_modules/

# Secrets / local config — never commit these
.env
.env.*
*.pem
*.key
aws-credentials*

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp

# Kiro spec/workspace files
.kiro/
